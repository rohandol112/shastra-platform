# Backend origin the same-origin proxy (/backend/*) forwards to (recommended).
# The browser only ever talks to the Next.js app, so the backend needs no CORS
# config and can stay on plain HTTP.
BACKEND_URL=http://localhost:8080

# Optional alternative: call the backend directly from the browser instead of
# proxying. Requires CORS_ORIGINS set on the backend, and an HTTPS backend if
# the frontend is served over HTTPS.
# NEXT_PUBLIC_API_URL=http://localhost:8080
